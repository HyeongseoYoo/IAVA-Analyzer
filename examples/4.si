init {
  INIT := 0;
  SVC := 1;
  IRQ := 2;
  FIQ := 3;
  INVALID := 100; 

  CurrentUser := INIT;
  Status := malloc(4, 0);

  Test := 0;

  handler 0 { CurrentUser := INVALID };
  handler 1 { *Status[CurrentUser] := -1 };
  handler 2 { Test := Test + 1 }
}

main {
  if CurrentUser = INVALID
  then CurrentUser := INIT
  else *Status[CurrentUser] := 1
}
